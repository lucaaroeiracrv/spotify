            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Música Encontrada?": {
      "main": [
        [
          {
            "node": "Preparar Resposta — Encontrada",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Preparar Resposta — Não Encontrada",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Preparar Resposta — Encontrada": {
      "main": [
        [
          {
            "node": "Responder — Encontrada",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Preparar Resposta — Não Encontrada": {
      "main": [
        [
          {
            "node": "Responder — Não Encontrada",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
