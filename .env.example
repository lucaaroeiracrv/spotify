# =======================
# EXEMPLO DE CONFIGURAÇÃO
# =======================
# Copie este arquivo para .env e preencha com suas credenciais
# O arquivo .env está no .gitignore e não será versionado

# Obtenha essas credenciais em: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=SEU_CLIENT_ID_AQUI
SPOTIFY_CLIENT_SECRET=SEU_CLIENT_SECRET_AQUI
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# =======================
# OPCIONAL - CLASSIFICAÇÃO HÍBRIDA COM IA
# =======================
# auto -> tenta OpenAI e depois Hugging Face
# rules -> usa apenas fallback local + metadados do Spotify
# huggingface -> força zero-shot via Hugging Face
# openai -> força classificação via OpenAI
CLASSIFICATION_PROVIDER=auto
GENRE_AI_ALWAYS_ON=false

# Tags de música e artista (recomendado)
LASTFM_API_KEY=

# Zero-shot classification por texto/metadados
HUGGINGFACE_API_KEY=

# Classificação semântica via LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
